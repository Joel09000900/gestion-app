# ── Frontend Jeloft — variables d'environnement ──
# Copier en `.env` en local ; sur Vercel/Netlify, les définir dans les settings du projet.
# (Les variables doivent commencer par REACT_APP_ pour être exposées au build CRA.)

# URL de l'API backend déployé, suffixe /api inclus.
# En local : http://localhost:5000/api ; en prod : https://ton-api.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# URL du serveur Socket.io (SANS /api).
# En local : http://localhost:5000 ; en prod : https://ton-api.onrender.com
REACT_APP_SOCKET_URL=http://localhost:5000

# Vercel/Netlify exécutent le build avec CI=true → CRA transforme les warnings ESLint
# en erreurs. Cette ligne évite l'échec du build. (À définir AUSSI dans les env vars Vercel.)
DISABLE_ESLINT_PLUGIN=true
