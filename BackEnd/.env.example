# ── Backend Jeloft — variables d'environnement ──
# Copier en `.env` en local ; sur Render, les définir dans Settings → Environment.

# Connexion PostgreSQL (NeonDB). NE PAS committer la vraie valeur.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret de signature JWT. En prod : longue chaîne aléatoire (ex. `openssl rand -hex 32`).
JWT_SECRET="remplace-par-un-secret-fort-et-aleatoire"

# Port d'écoute. En local 5000 ; sur Render, laissé vide (la plateforme l'injecte).
PORT=5000

# Origine autorisée (CORS + Socket.io) = URL du frontend.
# En local : http://localhost:3000 ; en prod : https://ton-app.vercel.app
CLIENT_URL="http://localhost:3000"
